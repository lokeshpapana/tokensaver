        <!-- API Section -->
        <section id="api" class="tool-card" style="margin-top: 32px;">
            <div class="tool-header"><h2 class="tool-title">Developer API</h2></div>
            <div class="tool-body">
                <p style="color: var(--text-secondary); margin-bottom: 16px;">Integrate TokenSaver into your workflow with our REST API.</p>
                <div style="background: var(--input-bg); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; overflow-x: auto; white-space: pre;">
<span style="color: var(--text-muted);"># Convert file</span>
curl -X POST https://api.tokensaver.dev/api/convert \
  -F "file=@code.py" \
  -F "mode=dense"

<span style="color: var(--text-muted);"># Convert text</span>
curl -X POST https://api.tokensaver.dev/api/convert-text \
  -H "Content-Type: application/json" \
  -d '{{"text": "your code", "mode": "dense"}}'

<span style="color: var(--text-muted);"># Batch convert (returns ZIP)</span>
curl -X POST "https://api.tokensaver.dev/api/convert-batch?mode=dense" \
  -F "files=@file1.py" -F "files=@file2.js" -o batch.zip
